{
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "lib": ["DOM", "ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["@solidjs/start/env", "vinxi/types/client"]
  },
  "exclude": [
    "*.config.mts",
    ".output",
    ".vinxi",
    "coverage",
    "dist",
    "node_modules"
  ],
  "extends": "@kurone-kito/typescript-config/tsconfig.json",
  "include": ["./**/*.mjs", "./**/*.mts", "./**/*.tsx"]
}
