{
  "name": "@kurone-kito/oneiron",
  "version": "0.1.0",
  "private": true,
  "description": "Dream Duels: The Battle for Oneiron",
  "keywords": ["cardgame", "oneiron", "simulator", "tabletalk"],
  "homepage": "https://github.com/kurone-kito/oneiron#readme",
  "bugs": "https://github.com/kurone-kito/oneiron/issues",
  "repository": "github:kurone-kito/oneiron",
  "license": "MIT",
  "author": "kurone-kito <krone@kit.black> (https://kit.black/)",
  "type": "module",
  "files": [],
  "workspaces": {
    "packages": ["./packages/*"]
  },
  "scripts": {
    "build": "pnpm run --workspace-concurrency=Infinity -r build",
    "clean": "pnpm run --no-bail \"/^clean:.+/\"",
    "clean:root": "rimraf -g \"*.tgz\" \"*.tsbuildinfo\" node_modules/.cache",
    "clean:sub": "pnpm run --parallel --workspace-concurrency=Infinity -r clean",
    "dev": "pnpm run --parallel --workspace-concurrency=Infinity -r dev",
    "lint": "pnpm run \"/lint:.+:check/\"",
    "lint:biome:check": "biome check",
    "lint:biome:fix": "biome check --write",
    "lint:cspell:check": "cspell lint --no-progress --show-suggestions -u \"./**/*\"",
    "lint:fix": "pnpm run lint:cspell:check && pnpm run \"/lint:.+:fix/\"",
    "lint:markdown:check": "markdownlint-cli2 \"**/*.md\"",
    "lint:markdown:fix": "markdownlint-cli2 --fix \"**/*.md\"",
    "prepare": "husky",
    "test": "pnpm run lint"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@cspell/cspell-types": "^9.0.2",
    "@kurone-kito/biome-config": "0.18.0",
    "@kurone-kito/commitlint-config": "^0.18.0",
    "@kurone-kito/cspell-config": "^0.18.0",
    "@kurone-kito/lint-staged-config": "^0.18.0",
    "@kurone-kito/markdownlint-config": "^0.18.0",
    "@kurone-kito/typescript-config": "^0.18.0",
    "cspell": "^9.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "markdownlint-cli2": "^0.18.1",
    "rimraf": "^6.0.1",
    "typescript": "~5.8.3"
  },
  "packageManager": "pnpm@10.11.1+sha512.e519b9f7639869dc8d5c3c5dfef73b3f091094b0a006d7317353c72b124e80e1afd429732e28705ad6bfa1ee879c1fce46c128ccebd3192101f43dd67c667912",
  "engines": {
    "node": "^20.11 || >=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
